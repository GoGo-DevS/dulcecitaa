# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Marca y canales
BRAND_NAME=Dulcecitaa
WEBSITE_URL=
WHATSAPP_URL=https://wa.me/56912345678
SHIPPING_COST=2500
PICKUP_POINT_LABEL=Retiro coordinado por WhatsApp
BUSINESS_HOURS=Lunes a sabado de 09:00 a 19:00
DEFAULT_OG_IMAGE=/static/img/hero/slide1.jpg

# Email (SMTP)
# Para probar envio real usa SMTP backend.
# En desarrollo sin SMTP puedes usar console para ver correos en terminal.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=no-reply@dulcecitaa.cl
CONTACT_EMAIL=ventas@dulcecitaa.cl
